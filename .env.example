# ============================================
# SAP Agentic AI - Ortam Degiskenleri SABLONU
# ============================================
# Bu dosyayi ".env" olarak kopyalayin ve kendi bilgilerinizle doldurun.
#   copy .env.example .env
# DIKKAT: .env dosyasi ASLA GitHub'a gonderilmez.
# ============================================

# --- GitHub ---
GITHUB_TOKEN=ghp_BURAYA_TOKEN_YAZIN
GITHUB_REPO=hasanbsc/agentic_ai

# --- SAP OData ---
SAP_BASE_URL=https://your-sap-server.com/sap/opu/odata/sap/
SAP_SERVICE=YMONO_AKT_PLN_SRV
SAP_USERNAME=SAP_KULLANICI_ADI
SAP_PASSWORD=SAP_SIFRE
SAP_VERIFY_SSL=true

# --- Genel ---
USE_SAMPLE_DATA=true
LOG_LEVEL=INFO
